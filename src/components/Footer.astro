---
import { Image } from 'astro:assets';
import Logoayudadefensoresfooter from '../assets/ayudadefensores-footer.webp';
import LogoFCI from '../assets/fci-footer.webp';
import { getLocaleFromUrl } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const homeUrl = locale === 'pt' ? '/pt/' : '/es/';
---

<!-- Newsletter Section -->
<section class="mt-22 flex justify-center px-4 sm:px-6">
  <div class="w-full max-w-334.25 bg-cafeoscuro rounded-xl flex flex-col md:flex-row items-center justify-between px-2 py-2 md:px-12 md:h-36 gap-2">
    <div class="text-white text-center md:text-left">
      <div class="font-semibold text-lg md:text-xl mb-1">Suscríbete al Newsletter</div>
      <div class="font-light text-base md:text-lg">de Democracia Ambiental</div>
    </div>
    <div class="flex flex-col sm:flex-row items-center gap-4 w-full md:w-auto">
      <input 
        type="email" 
        placeholder="Escribe tu correo aquí" 
        class="md:w-94 sm:w-64 h-10 bg-white rounded-lg flex items-center px-4 text-cafeoscuro font-light text-sm md:text-base outline-none focus:ring-2 focus:ring-cafemedio"
      />
      <button class="px-4 py-1.5 bg-cafemedio rounded-full text-white font-semibold text-sm md:text-lg uppercase cursor-pointer whitespace-nowrap hover:bg-verde transition-colors">suscribirse</button>
    </div>
  </div>
</section>

<!-- Footer -->
<section class="-mt-6">
  <footer class="py-8 bg-cafeoscuro text-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-16 items-center">
        <div class="text-center md:text-left mx-auto">
          <a href="mailto:contacto@ayudadefensores.org"><p class="text-sm font-light">contacto@ayudadefensores.org</p></a>
        </div>
        <div class="text-center">
          <a href={homeUrl}>
            <Image src={Logoayudadefensoresfooter} alt="Logo Ayuda Defensores Footer" class="md:h-auto mx-auto h-10 w-auto">
          </a>
        </div>
        <div class="text-center md:text-right flex flex-row items-center justify-center md:justify-end gap-2">
          <span class="text-sm font-light">Un proyecto de</span>
          <a href="https://ciudadaniai.org" target="_blank"><Image src={LogoFCI} alt="Logo Fundación Ciudadanía Inteligente" class="md:h-auto mx-auto h-8 w-auto" /></a>
        </div>
      </div>
    </div>
  </footer>
</section>

<!-- Disclaimer Bar -->
<div class="h-10 bg-verde flex items-center justify-center">
  <span class="text-white text-xs font-light px-4 text-center">Ayuda Defensores de Ciudadanía Inteligente | 2026 Todos los derechos reservados</span>
</div>
