---
import { Image } from 'astro:assets';
import Logoayudadefensoresfooter from '../assets/ayudadefensores-footer.webp';
import LogoFCI from '../assets/fci-footer.webp';
import { getLocaleFromUrl } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const homeUrl = locale === 'pt' ? '/pt/' : '/es/';
---

<!-- Newsletter Section -->
<section class="mt-22 flex justify-center px-4 sm:px-6">
  <div class="w-full max-w-4xl bg-cafeoscuro rounded-xl flex flex-col sm:flex-row items-center justify-center sm:justify-between px-6 sm:px-10 py-8 sm:py-6 gap-3 sm:gap-6">
    <div class="text-white flex flex-col sm:flex-row items-center sm:items-start gap-0 sm:gap-2">
      <span class="font-semibold text-lg sm:text-xl">Suscríbete al Newsletter</span>
      <span class="font-light text-base sm:text-lg">de Democracia Ambiental</span>
    </div>
    <a href="http://eepurl.com/jCCb2g"><button class="px-6 py-2.5 bg-cafemedio rounded-full text-white font-semibold text-base sm:text-lg uppercase cursor-pointer whitespace-nowrap hover:bg-verde transition-colors">recibir newsletter</button></a>
  </div>
</section>

<!-- Footer -->
<section class="-mt-6">
  <footer class="py-8 bg-cafeoscuro text-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-16 items-center">
        <div class="text-center md:text-left mx-auto">
          <a href="mailto:ayudadefensores@ciudadaniai.org"><p class="text-sm font-light">ayudadefensores@ciudadaniai.org</p></a>
        </div>
        <div class="text-center">
          <a href={homeUrl}>
            <Image src={Logoayudadefensoresfooter} alt="Logo Ayuda Defensores Footer" class="md:h-auto mx-auto h-10 w-auto">
          </a>
        </div>
        <div class="text-center md:text-right flex flex-row items-center justify-center md:justify-end gap-2">
          <span class="text-sm font-light">Un proyecto de</span>
          <a href="https://ciudadaniai.org" target="_blank"><Image src={LogoFCI} alt="Logo Fundación Ciudadanía Inteligente" class="md:h-auto mx-auto h-8 w-auto" /></a>
        </div>
      </div>
    </div>
  </footer>
</section>

<!-- Disclaimer Bar -->
<div class="h-10 bg-verde flex items-center justify-center">
  <span class="text-white text-xs font-light px-4 text-center">Ayuda Defensores de Ciudadanía Inteligente | 2026 Todos los derechos reservados</span>
</div>
