---
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'pt' } },
  ];
}

import Layout from '../../layouts/Layout-paises.astro';
import { t } from '../../i18n/utils.ts';

const { lang } = Astro.params;
const locale = lang === 'pt' ? 'pt' : 'es';
const homeUrl = locale === 'pt' ? '/pt/' : '/';

const paises = [
  { id: 'mexico', nombre: locale === 'pt' ? 'México' : 'México' },
  { id: 'colombia', nombre: locale === 'pt' ? 'Colômbia' : 'Colombia' },
  { id: 'brasil', nombre: locale === 'pt' ? 'Brasil' : 'Brasil' },
  { id: 'argentina', nombre: locale === 'pt' ? 'Argentina' : 'Argentina' },
  { id: 'peru', nombre: locale === 'pt' ? 'Peru' : 'Perú' },
  { id: 'uruguay', nombre: locale === 'pt' ? 'Uruguai' : 'Uruguay' },
  { id: 'chile', nombre: locale === 'pt' ? 'Chile' : 'Chile' }
];
---

<Layout title={t('nav.apoyoPorPais', locale)}>

  <!-- Barra inicial -->
  <section class="flex w-full h-auto md:h-60 bg-[url(/bg-ayudadefensores.png)] bg-cover relative py-2 md:py-0">
    <div class="absolute inset-0 bg-cover -z-10"></div>
    <div class="w-full px-4 flex flex-col items-center gap-4 pt-16 pb-6 md:hidden">
      <span class="w-fit inline-block rounded-2xl px-4 py-1 bg-white text-verde text-[12px] font-medium uppercase"><a href={homeUrl} class="hover:text-cafemedio">{t('nav.inicio', locale)}</a> / {t('nav.apoyoPorPais', locale)}</span>
      <h1 class="text-3xl font-extrabold text-cafemedio text-center">{t('apoyo.titulo', locale)}</h1>
      <p class="text-cafeoscuro text-base font-medium text-center leading-relaxed">{t('apoyo.descripcion', locale)}</p>
    </div>
    <div class="hidden md:flex absolute md:left-[150px] md:mt-4 top-1/3 -translate-y-1/2 w-[calc(100%-150px)] pr-8 flex flex-col gap-8">
      <span class="w-fit inline-block rounded-2xl px-4 py-1 bg-white text-verde text-[12px] font-medium uppercase"><a href={homeUrl} class="hover:text-cafemedio">{t('nav.inicio', locale)}</a> / {t('nav.apoyoPorPais', locale)}</span>
      <div class="flex items-start">
        <h1 class="text-6xl font-extrabold text-cafemedio w-[450px] flex-shrink-0 whitespace-nowrap">{t('apoyo.titulo', locale)}</h1>
        <p class="text-cafeoscuro text-lg font-medium max-w-2xl text-left leading-relaxed ml-[300px]">{t('apoyo.descripcion', locale)}</p>
      </div>
    </div>
  </section>

  <!-- Buscador por países -->
  <div class="container max-w-8xl mx-auto px-4 min-h-[400px] overflow-x-hidden">
     <div class="flex flex-wrap gap-4 justify-center py-8">
     <div class="text-cafeoscuro text-lg font-semibold mt-1">{t('apoyo.seleccionarPais', locale)}</div> {paises.map((pais) => (
      <button
        hx-get={`/paises-parciales/${pais.id}`}
        hx-target="#contenido-pais"
        hx-swap="innerHTML transition:true"
        class="px-4 py-2 bg-cafeoscuro text-white font-medium rounded-full hover:bg-cafemedio transition cursor-pointer"
      >
        {pais.nombre}
      </button>
      ))}
    </div>
    <div id="contenido-pais"></div>

  </div>

  <style>
  .fade-in {
    animation: fadeIn 0.3s ease-in-out;
  }

  @keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
  }
  </style>
</Layout>
