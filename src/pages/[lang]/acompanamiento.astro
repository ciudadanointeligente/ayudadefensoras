---
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'pt' } },
  ];
}

import Layout from '../../layouts/Layout-paises.astro';
import { t } from '../../i18n/utils.ts';

const { lang } = Astro.params;
const locale = lang === 'pt' ? 'pt' : 'es';
const homeUrl = locale === 'pt' ? '/pt/' : '/';
---

<Layout title={t('nav.acompanamiento', locale)}>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    Alpine.data('acompanamiento', () => ({
      selectedPais: null,
      paises: [
        {
          id: 'brasil',
          nombre: 'Brasil',
          organizacionLabel: 'Organizaciones en:',
          organizaciones: [
            {
              nombre: 'Justiça Global',
              descripcion: 'Actúa desde 1999 en defensa de los derechos humanos.',
              link: 'https://www.global.org.br/es/pagina-de-inicio/',
              linkTexto: 'global.org.br'
            },
            {
              nombre: 'Terra de Direitos',
              descripcion: 'Actúa en la defensa, promoción y efectividad de derechos humanos, especialmente económicos, culturales, sociales y ambientales.',
              link: 'https://terradedireitos.org.br/es/',
              linkTexto: 'terradedireitos.org.br'
            }
          ]
        },
        {
          id: 'chile',
          nombre: 'Chile',
          organizacionLabel: 'Organizaciones en:',
          organizaciones: [
            {
              nombre: 'Escazú Ahora',
              descripcion: 'Trabaja para promover y fiscalizar la implementación plena, efectiva y ambiciosa del Acuerdo de Escazú en Chile y Latinoamérica.',
              link: 'https://www.escazuahorachile.cl/',
              linkTexto: 'escazuahorachile.cl'
            }
          ]
        },
        {
          id: 'colombia',
          nombre: 'Colombia',
          organizacionLabel: 'Organizaciones en:',
          organizaciones: [
            {
              nombre: 'Somos Defensores',
              descripcion: 'Espacio conformado por varias ONG de derechos humanos (Asociación MINGA, Benposta Nación de Muchachos y la Comisión Colombiana de Juristas) para prevenir agresiones de personas defensoras de derechos humanos.',
              link: 'https://somosdefensores.org/nosotros/',
              linkTexto: 'somosdefensores.org',
              nota: 'No llevan causas legales, pero acompañan en procesos de relocalización temporal, monitoreo de agresiones, atención psicosocial.'
            }
          ]
        }
      ],
      seleccionarPais(id) {
        this.selectedPais = this.selectedPais === id ? null : id;
      }
    }));
  });
</script>

  <!-- Barra inicial -->
  <section class="flex w-full h-auto md:h-60 bg-[url(/bg-ayudadefensores.png)] bg-cover relative py-2 md:py-0">
    <div class="absolute inset-0 bg-cover -z-10"></div>
    <div class="w-full px-4 flex flex-col items-center gap-4 pt-16 pb-6 md:hidden">
      <span class="w-fit inline-block rounded-2xl px-4 py-1 bg-white text-verde text-[12px] font-medium uppercase"><a href={homeUrl} class="hover:text-cafemedio">{t('nav.inicio', locale)}</a> / {t('nav.acompanamiento', locale)}</span>
      <h1 class="text-3xl font-extrabold text-cafemedio text-center">{t('acompanamiento.titulo', locale)}</h1>
      <p class="text-cafeoscuro text-base font-medium text-center leading-relaxed">{t('acompanamiento.descripcion', locale)}</p>
    </div>
    <div class="hidden md:flex absolute md:left-[150px] md:mt-4 top-1/3 -translate-y-1/2 w-[calc(100%-150px)] pr-8 flex flex-col gap-8">
      <span class="w-fit inline-block rounded-2xl px-4 py-1 bg-white text-verde text-[12px] font-medium uppercase"><a href={homeUrl} class="hover:text-cafemedio">{t('nav.inicio', locale)}</a> / {t('nav.acompanamiento', locale)}</span>
      <div class="flex items-start">
        <h1 class="text-6xl font-extrabold text-cafemedio w-[450px] flex-shrink-0 whitespace-nowrap">{t('acompanamiento.titulo', locale)}</h1>
        <p class="text-cafeoscuro text-lg font-medium max-w-2xl text-left leading-relaxed ml-[300px]">{t('acompanamiento.descripcion', locale)}</p>
      </div>
    </div>
  </section>

  <!-- Texto principal -->
  <section class="mt-12 md:mt-16 flex justify-center">
    <div class="text-center">
      <div class="text-stone-600 text-xl md:text-5xl font-medium font-['Geologica'] leading-tight md:leading-10">Organizaciones que trabajan a nivel</div>
      <div class="text-cafemedio text-2xl md:text-7xl font-extrabold font-['Geologica'] uppercase leading-tight md:leading-[77.49px]">regional o global</div>
    </div>
  </section>

  <!-- Cajas de organizaciones -->
  <section class="mt-12 md:mt-16 flex justify-center pb-16 md:pb-12">
    <div class="container max-w-7xl mx-auto px-4">
      <div class="flex flex-col md:flex-row flex-wrap justify-center gap-8">
        
        <!-- Caja 1: Front Line Defenders -->
        <div class="w-full sm:w-72 flex flex-col mx-auto sm:mx-0">
          <div class="w-full sm:w-72 h-16 bg-verde rounded-[20px] rounded-b-none flex items-center justify-center">
            <div class="text-white text-xl font-semibold font-['Geologica'] text-center">Front Line Defenders</div>
          </div>
          <div class="w-full sm:w-72 h-auto sm:h-64 bg-lime-200/40 rounded-[20px] rounded-t-none p-4 flex flex-col">
            <p class="text-stone-600 text-base font-normal font-['Geologica'] leading-5">Organización internacional de Derechos Humanos, enfocada en proteger a personas defensoras en riesgo. Cuenta con una línea de contacto para emergencias.</p>
            <div class="mt-4 sm:mt-auto pt-2.5 flex justify-center">
              <a href="https://www.frontlinedefenders.org/es" target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 bg-cafemedio rounded-[34.60px] inline-flex justify-center items-center gap-3">
                <span class="text-white text-sm font-black font-['Geologica'] uppercase">revisar sitio web</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Caja 2: Global Witness -->
        <div class="w-full sm:w-72 flex flex-col mx-auto sm:mx-0">
          <div class="w-full sm:w-72 h-16 bg-verde rounded-[20px] rounded-b-none flex items-center justify-center">
            <div class="text-white text-xl font-semibold font-['Geologica'] text-center">Global Witness</div>
          </div>
          <div class="w-full sm:w-72 h-auto sm:h-64 bg-lime-200/40 rounded-[20px] rounded-t-none p-4 flex flex-col">
            <p class="text-stone-600 text-base font-normal font-['Geologica'] leading-5">Dedicados a exponer a las industrias que se benefician de la emergencia climática y apoyan a las personas que luchan para defender sus comunidades y sus derechos.</p>
            <div class="mt-4 sm:mt-auto pt-2.5 flex justify-center">
              <a href="https://www.globalwitness.org/es" target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 bg-cafemedio rounded-[34.60px] inline-flex justify-center items-center gap-3">
                <span class="text-white text-sm font-black font-['Geologica'] uppercase">revisar sitio web</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Caja 3: Protection International -->
        <div class="w-full sm:w-72 flex flex-col mx-auto sm:mx-0">
          <div class="w-full sm:w-72 h-16 bg-verde rounded-[20px] rounded-b-none flex items-center justify-center">
            <div class="text-white text-xl font-semibold font-['Geologica'] text-center">Protection International</div>
          </div>
          <div class="w-full sm:w-72 h-auto sm:h-64 bg-lime-200/40 rounded-[20px] rounded-t-none p-4 flex flex-col">
            <p class="text-stone-600 text-base font-normal font-['Geologica'] leading-5">Se especializa en trabajo preventivo, acompañando a personas defensoras de Derechos Humanos a crear sus estrategias de protección.</p>
            <div class="mt-4 sm:mt-auto pt-2.5 flex justify-center">
              <a href="https://www.protectioninternational.org/our-work/what-we-do/" target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 bg-cafemedio rounded-[34.60px] inline-flex justify-center items-center gap-3">
                <span class="text-white text-sm font-black font-['Geologica'] uppercase">revisar sitio web</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Caja 4: Fondo de Acción Urgente -->
        <div class="w-full sm:w-72 flex flex-col mx-auto sm:mx-0">
          <div class="w-full sm:w-72 h-16 bg-verde rounded-[20px] rounded-b-none flex items-center justify-center">
            <div class="text-white text-xl font-semibold font-['Geologica'] text-center">Fondo de Acción Urgente</div>
          </div>
          <div class="w-full sm:w-72 h-auto sm:h-64 bg-lime-200/40 rounded-[20px] rounded-t-none p-4 flex flex-col">
            <p class="text-stone-600 text-base font-normal font-['Geologica'] leading-5">Fondo para América Latina y el Caribe hispanohablante, apoyando el trabajo de personas defensoras y sus movimientos desde una perspectiva feminista.</p>
            <div class="mt-4 sm:mt-auto pt-2.5 flex justify-center">
              <a href="https://www.fondoaccionurgente.org.co" target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 bg-cafemedio rounded-[34.60px] inline-flex justify-center items-center gap-3">
                <span class="text-white text-sm font-black font-['Geologica'] uppercase">revisar sitio web</span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Flecha -->
  <section class="mt-2 md:mt-15.5 flex justify-center -z-10">
    <svg xmlns="http://www.w3.org/2000/svg" width="12" height="85" viewBox="0 0 12 85" fill="none">
      <path d="M5.77342 84.7735L11.5469 79L5.77342 73.2265L-8.35618e-05 79L5.77342 84.7735ZM5.77344 0L4.77344 -2.32254e-07L4.77342 79L5.77342 79L6.77342 79L6.77344 2.32254e-07L5.77344 0Z" fill="#818B3E"/>
    </svg>
  </section>

  <!-- Título Organizaciones por país -->
  <section class="mt-12 md:mt-16 flex justify-center">
    <div class="text-center">
      <div class="text-stone-600 text-3xl md:text-5xl font-medium font-['Geologica'] leading-tight md:leading-10">Organizaciones</div>
      <div class="text-cafemedio text-4xl md:text-7xl font-extrabold font-['Geologica'] uppercase leading-tight md:leading-[88.56px]">POR PAÍS</div>
    </div>
  </section>

  <!-- Selector de países -->
  <section class="mt-8 md:mt-12 flex justify-center" x-data="acompanamiento">
    <div class="container max-w-8xl mx-auto px-4">
      <div class="flex flex-wrap gap-2 sm:gap-4 justify-center py-4 sm:py-6">
        <template x-for="pais in paises" :key="pais.id">
          <button
            @click="seleccionarPais(pais.id)"
            :class="selectedPais === pais.id ? 'bg-verde' : 'bg-cafeoscuro hover:bg-cafemedio'"
            class="px-3 sm:px-6 py-2 sm:py-3 text-white font-medium rounded-full transition cursor-pointer text-sm sm:text-lg"
          >
            <span x-text="pais.nombre"></span>
          </button>
        </template>
      </div>

      <!-- Contenido del país seleccionado -->
      <div x-show="selectedPais !== null" x-transition class="mt-8 pb-16">
        <template x-for="pais in paises" :key="pais.id">
          <div x-show="selectedPais === pais.id">
            <div class="flex flex-col md:flex-row gap-4 md:gap-12">
              <!-- Columna izquierda -->
              <div class="w-full md:w-[40%]">
                <div class="w-full text-stone-600 text-lg md:text-xl font-black font-['Geologica'] leading-6">
                  <span class="bg-amarillo p-1 rounded-md" x-text="pais.organizacionLabel"></span>
                </div>
                <div class="text-cafemedio text-4xl md:text-7xl font-black font-['Geologica'] uppercase leading-tight md:leading-[77.49px] mt-4" x-text="pais.nombre"></div>
                <p class="text-stone-600 text-base md:text-lg font-normal font-['Geologica'] leading-5 md:leading-6 mt-4">Estas organizaciones trabajan a nivel nacional y territorial, y pueden orientar, acompañar o apoyar según cada caso.</p>
              </div>

              <!-- Columna derecha -->
              <div class="w-full md:w-[60%]">
                <div class="bg-lime-200/40 rounded-xl p-4 md:p-6">
                  <template x-for="org in pais.organizaciones" :key="org.nombre">
                    <div class="mb-4 md:mb-6 last:mb-0">
                      <h4 class="text-cafeoscuro text-lg md:text-xl font-bold font-['Geologica'] uppercase leading-5 md:leading-6 mb-2" x-text="org.nombre"></h4>
                      <p class="text-stone-600 text-sm md:text-base font-normal font-['Geologica'] leading-5 mb-2" x-text="org.descripcion"></p>
                      <a :href="org.link" target="_blank" rel="noopener noreferrer" class="text-cafemedio text-sm md:text-base font-normal font-['Geologica'] underline block break-all" x-text="org.linkTexto"></a>
                      <p x-show="org.nota" class="text-stone-600 text-xs md:text-sm font-normal font-['Geologica'] leading-5 mt-2 italic" x-text="org.nota"></p>
                    </div>
                  </template>
                </div>
              </div>
            </div>
          </div>
        </template>
      </div>
    </div>
  </section>

  <!-- Flecha vertical -->
  <section class="mt-2 md:mt-12 flex justify-center">
    <svg xmlns="http://www.w3.org/2000/svg" width="12" height="85" viewBox="0 0 12 85" fill="none">
      <path d="M5.77342 84.7735L11.5469 79L5.77342 73.2265L-8.35618e-05 79L5.77342 84.7735ZM5.77344 0L4.77344 -2.32254e-07L4.77342 79L5.77342 79L6.77342 79L6.77344 2.32254e-07L5.77344 0Z" fill="#818B3E"/>
    </svg>
  </section>

  <!-- Texto final -->
  <section class="mt-12 md:mt-16 flex justify-center pb-16 md:pb-32">
    <div class="text-center">
      <div class="text-stone-600 text-xl md:text-5xl font-medium font-['Geologica'] leading-tight md:leading-10">¿Organización que trabaja a nivel</div>
      <div class="text-cafemedio text-2xl md:text-7xl font-extrabold font-['Geologica'] uppercase leading-tight md:leading-[89.69px]">REGIONAL O GLOBAL?</div>
      <div class="mt-4 md:mt-8">
        <a href="mailto:ayudadefensores@ciudadaniai.org" class="inline-block px-6 md:px-8 py-3 md:py-4 bg-verde text-white text-base md:text-xl font-bold font-['Geologica'] uppercase rounded-full hover:bg-cafemedio transition">
          Contáctanos
        </a>
      </div>
    </div>
  </section>

  <style>
    [x-cloak] { display: none !important; }
  </style>
</Layout>

