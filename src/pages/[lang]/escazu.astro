---
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'pt' } },
  ];
}

import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/utils.ts';

const { lang } = Astro.params;
const locale = lang === 'pt' ? 'pt' : 'es';
const homeUrl = locale === 'pt' ? '/pt/' : '/';
---

<Layout title={t('nav.escazu', locale)}>

  <!-- Barra inicial -->
  <section class="flex w-full h-auto md:h-60 bg-[url(/bg-ayudadefensores.png)] bg-cover relative py-2 md:py-0">
    <div class="absolute inset-0 bg-cover -z-10"></div>
    <div class="w-full px-4 flex flex-col items-center gap-4 pt-16 pb-6 md:hidden">
      <span class="w-fit inline-block rounded-2xl px-4 py-1 bg-white text-verde text-[12px] font-medium uppercase"><a href={homeUrl} class="hover:text-cafemedio">{t('nav.inicio', locale)}</a> / {t('nav.escazu', locale)}</span>
      <h1 class="text-3xl font-extrabold text-cafemedio text-center">SOBRE {t('nav.escazu', locale).toUpperCase()}</h1>
      <p class="text-cafeoscuro text-base font-medium text-center leading-relaxed">{t('escazu.descripcion', locale)}</p>
    </div>
    <div class="hidden md:flex absolute md:left-[150px] md:mt-4 top-1/3 -translate-y-1/2 w-[calc(100%-150px)] pr-8 flex flex-col gap-8">
      <span class="w-fit inline-block rounded-2xl px-4 py-1 bg-white text-verde text-[12px] font-medium uppercase"><a href={homeUrl} class="hover:text-cafemedio">{t('nav.inicio', locale)}</a> / {t('nav.escazu', locale)}</span>
      <div class="flex items-start">
        <h1 class="text-6xl font-extrabold text-cafemedio w-[450px] flex-shrink-0 whitespace-nowrap">SOBRE {t('nav.escazu', locale).toUpperCase()}</h1>
        <p class="text-cafeoscuro text-lg font-medium max-w-2xl text-left leading-relaxed ml-[300px]">{t('escazu.descripcion', locale)}</p>
      </div>
    </div>
  </section>

  <!-- Contenido principal en dos columnas -->
  <section class="mt-12 md:mt-16 flex justify-center pb-16 md:pb-32">
    <div class="container max-w-7xl mx-auto px-4">
      <div class="flex flex-col md:flex-row gap-8 md:gap-20">
        <!-- Columna izquierda -->
        <div class="w-full md:w-1/2">
          <div class="text-stone-600 text-3xl md:text-5xl font-medium font-['Geologica'] leading-tight md:leading-[49.83px]">¿Qué es el</div>
          <div class="text-cafemedio text-4xl md:text-7xl font-extrabold font-['Geologica'] uppercase leading-tight md:leading-[89.69px] mt-2">Acuerdo<br/>de Escazú?</div>
          <div class="mt-6 md:mt-8 bg-amber-50 rounded-xl p-4 inline-block">
            <span class="text-stone-600 text-base md:text-xl font-bold font-['Geologica'] leading-6">Más información sobre el Acuerdo en Chile:</span>
            <span class="text-cafemedio text-base md:text-xl font-black font-['Geologica'] underline leading-6 block">acuerdodeescazu.cl</span>
          </div>
        </div>

        <!-- Columna derecha -->
        <div class="w-full md:w-1/2">
          <p class="text-stone-600 text-base md:text-lg font-normal font-['Geologica'] leading-6">
            El Acuerdo de Escazú es el <span class="bg-amarillo px-1 rounded font-semibold">Acuerdo Regional sobre Acceso a la Información, Participación Pública y Acceso a la Justicia en Asuntos Ambientales en América Latina y el Caribe</span>. Fue adoptado el 2018 y entró en vigor el 2021.
          </p>
          <p class="text-stone-600 text-base md:text-lg font-normal font-['Geologica'] leading-6 mt-4">
            Uno de sus pilares (Artículo 9) es la <span class="bg-amarillo px-1 rounded font-semibold">protección de las personas defensoras de derechos humanos ambientales</span>. Los Estados parte deben garantizar un entorno seguro para que defensores/as y organizaciones puedan trabajar sin amenazas ni restricciones.
          </p>
        </div>
      </div>
    </div>
  </section>

</Layout>
