---
import { t } from '../../i18n/utils.ts';
import Accordion from '../../components/Accordion.astro';

const url = Astro.url.pathname;
const locale = url.includes('/pt/') ? 'pt' : 'es';

const ubicaciones = [
  {
    id: 'santiago',
    titulo: 'Región Metropolitana (Santiago)',
    contenido: `
      <p class="text-white text-lg font-bold font-['Geologica'] leading-6 mb-2">Defensoría de los Derechos de la Niñez:</p>
      <p class="text-white text-lg font-normal font-['Geologica'] leading-6">
        Dirección: Morandé #360, Santiago Centro.<br/>
        Teléfono:<br/>
        +56 2 2617 4000<br/>
        Correo: <a href="mailto:contacto@defensorianinez.cl" class="text-white underline">contacto@defensorianinez.cl</a>
      </p>
    `
  },
  {
    id: 'valparaiso',
    titulo: 'Región de Valparaíso',
    contenido: `
      <p class="text-white text-lg font-bold font-['Geologica'] leading-6 mb-2">Instituto Nacional de Derechos Humanos:</p>
      <p class="text-white text-lg font-normal font-['Geologica'] leading-6">
        Dirección: Manuel Montt #750, Valparaíso.<br/>
        Teléfono:<br/>
        +56 32 250 3700<br/>
        Correo: <a href="mailto:indh@indh.cl" class="text-white underline">indh@indh.cl</a>
      </p>
    `
  },
  {
    id: 'biobio',
    titulo: 'Región del Biobío (Concepción)',
    contenido: `
      <p class="text-white text-lg font-bold font-['Geologica'] leading-6 mb-2">Seremi de Derechos Humanos - Biobío:</p>
      <p class="text-white text-lg font-normal font-['Geologica'] leading-6">
        Dirección: Colo-Colo #280, Concepción.<br/>
        Teléfono:<br/>
        +56 41 224 5500<br/>
        Correo: <a href="mailto:seremi.biobio@minsegpres.gob.cl" class="text-white underline">seremi.biobio@minsegpres.gob.cl</a>
      </p>
    `
  }
];
---

<div class="p-6 bg-white">
  <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-2 p-12">
    <h2 class="text-5xl md:text-7xl text-right font-extrabold text-cafemedio">{t('pais.chile.titulo', locale)}</h2>
    <div class="md:ml-12 md:mr-22 text-cafeoscuro text-[16px]">
      <p class="mb-2 font-bold">{t('pais.chile.descripcion', locale)}</p>
    </div>
  </div>
  <p class="text-center mt-10 uppercase text-cafeoscuro font-bold">{t('pais.chile.accionEstatal', locale) || 'Acción estatal y entidades de apoyo en Chile:'}</p>
  
  <div class="container max-w-4xl mx-auto px-4 mt-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start">
      {ubicaciones.map((ubicacion) => (
        <Accordion 
          id={ubicacion.id}
          title={ubicacion.titulo}
          content={ubicacion.contenido}
        />
      ))}
    </div>
  </div>
</div>
