---
import { t } from '../../i18n/utils.ts';
import Accordion from '../../components/Accordion.astro';

const url = Astro.url.pathname;
const locale = url.includes('/pt/') ? 'pt' : 'es';

const ubicaciones = [
  {
    id: 'ministerio-justicia',
    titulo: 'Ministerio de Justicia y Derechos Humanos',
    contenido: `
      <p class="text-white text-lg font-bold font-['Geologica'] leading-6 mb-2">Guía práctica para la protección de personas defensoras ambientales.</p>
      <p class="text-white text-lg font-normal font-['Geologica'] leading-6">
        Más información: <a href="https://cdn.www.gob.pe/uploads/document/file/3265462/Gu%C3%ADa%20pr%C3%A1ctica%20protecci%C3%B3n%20personas%20defensoras%20ambientales.pdf" target="_blank" rel="noopener noreferrer" class="text-white underline">Descargar guía</a>
      </p>
    `
  }
];
---

<div class="p-6 bg-white">
  <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-2 p-12">
    <h2 class="text-5xl md:text-7xl text-right font-extrabold text-cafemedio">{t('pais.peru.titulo', locale)}</h2>
    <div class="md:ml-12 md:mr-22 text-cafeoscuro text-[16px]">
      <p class="mb-2 font-bold">{t('pais.peru.descripcion', locale)}</p>
      <p class="mb-2">{t('pais.peru.direccion', locale)}</p>
      <p class="mb-2">{t('pais.peru.telefono', locale)}</p>
      <p>{t('pais.peru.correo', locale)}</p>
    </div>
  </div>
  <p class="text-center mt-10 uppercase text-cafeoscuro font-bold">{t('pais.peru.accionEstatal', locale)}</p>
  
  <div class="container max-w-4xl mx-auto px-4 mt-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start">
      {ubicaciones.map((ubicacion) => (
        <Accordion 
          id={ubicacion.id}
          title={ubicacion.titulo}
          content={ubicacion.contenido}
        />
      ))}
    </div>
  </div>
</div>