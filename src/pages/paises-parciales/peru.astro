---
import { t } from '../../i18n/utils.ts';
import Accordion from '../../components/Accordion.astro';

const url = Astro.url.pathname;
const locale = url.includes('/pt/') ? 'pt' : 'es';

const ubicaciones = [
  {
    id: 'lima',
    titulo: 'Lima',
    contenido: `
      <p class="text-white text-lg font-bold font-['Geologica'] leading-6 mb-2">Defensoría del Pueblo:</p>
      <p class="text-white text-lg font-normal font-['Geologica'] leading-6">
        Dirección: Jr. Ucayali #388, Lima Centro.<br/>
        Teléfono:<br/>
        +51 1 311-0300<br/>
        Correo: <a href="mailto:informes@defensoria.gob.pe" class="text-white underline">informes@defensoria.gob.pe</a>
      </p>
    `
  },
  {
    id: 'arequipa',
    titulo: 'Arequipa',
    contenido: `
      <p class="text-white text-lg font-bold font-['Geologica'] leading-6 mb-2">Defensoría del Pueblo - Oficina Regional Arequipa:</p>
      <p class="text-white text-lg font-normal font-['Geologica'] leading-6">
        Dirección: Calle La Merced #108, Cercado de Arequipa.<br/>
        Teléfono:<br/>
        +51 54 215-300<br/>
        Correo: <a href="mailto:arequipa@defensoria.gob.pe" class="text-white underline">arequipa@defensoria.gob.pe</a>
      </p>
    `
  },
  {
    id: 'cusco',
    titulo: 'Cusco',
    contenido: `
      <p class="text-white text-lg font-bold font-['Geologica'] leading-6 mb-2">Defensoría del Pueblo - Oficina Regional Cusco:</p>
      <p class="text-white text-lg font-normal font-['Geologica'] leading-6">
        Dirección: Av. Tullumayo #463, Cusco.<br/>
        Teléfono:<br/>
        +51 84 240-300<br/>
        Correo: <a href="mailto:cusco@defensoria.gob.pe" class="text-white underline">cusco@defensoria.gob.pe</a>
      </p>
    `
  }
];
---

<div class="p-6 bg-white">
  <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-2 p-12">
    <h2 class="text-5xl md:text-7xl text-right font-extrabold text-cafemedio">{t('pais.peru.titulo', locale)}</h2>
    <div class="md:ml-12 md:mr-22 text-cafeoscuro text-[16px]">
      <p class="mb-2 font-bold">{t('pais.peru.descripcion', locale)}</p>
    </div>
  </div>
  <p class="text-center mt-10 uppercase text-cafeoscuro font-bold">Acción estatal y entidades de apoyo en Perú:</p>
  
  <div class="container max-w-4xl mx-auto px-4 mt-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start">
      {ubicaciones.map((ubicacion) => (
        <Accordion 
          id={ubicacion.id}
          title={ubicacion.titulo}
          content={ubicacion.contenido}
        />
      ))}
    </div>
  </div>
</div>
