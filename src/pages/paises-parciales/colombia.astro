---
import { t } from '../../i18n/utils.ts';

const url = Astro.url.pathname;
const locale = url.includes('/pt/') ? 'pt' : 'es';

const ubicaciones = [
  { id: 'ministerio-ambiente', titulo: 'Ministerio de Ambiente', contenido: `
    <div class="w-full text-stone-600 text-xl font-black  leading-6 mb-2"><span class="bg-amarillo p-1 rounded-md">Medidas de protección para liderazgos ambientales.</span></div>
    <div class="w-full mt-3">
      <span class="text-cafemedio text-lg font-bold ">Más información:</span>
      <a href="https://www.minambiente.gov.co/lideres-ambientales/identificacion-y-proteccion/" target="_blank" rel="noopener noreferrer" class="text-stone-600 text-lg font-normal  underline block">https://www.minambiente.gov.co/lideres-ambientales/identificacion-y-proteccion/</a>
    </div>
  ` },
  { id: 'defensoria-pueblo', titulo: 'Defensoría del Pueblo', contenido: `
    <div class="w-full text-stone-600 text-xl font-black  leading-6 mb-2"><span class="bg-amarillo p-1 rounded-md">Protege y promociona los derechos humanos en Colombia.</span></div>
    <div class="w-full mt-3">
      <span class="text-cafemedio text-lg font-bold ">Sitio web:</span>
      <a href="https://www.defensoria.gov.co/en/web/guest" target="_blank" rel="noopener noreferrer" class="text-stone-600 text-lg font-normal  underline block">https://www.defensoria.gov.co/en/web/guest</a>
    </div>
    <div class="w-full mt-3">
      <span class="text-cafemedio text-lg font-bold ">Directorio:</span>
      <a href="https://www.defensoria.gov.co/en/directorio-de-dependencias" target="_blank" rel="noopener noreferrer" class="text-stone-600 text-lg font-normal  underline block">https://www.defensoria.gov.co/en/directorio-de-dependencias</a>
    </div>
  ` }
];

const ubicacionesJson = JSON.stringify(ubicaciones);
---

<div class="bg-white mt-6" x-data={`{ selectedId: null, ubicaciones: ${ubicacionesJson} }`}>
  <div class="flex flex-col md:flex-row gap-6 md:gap-5 px-4 md:px-6 py-4 md:py-6 max-w-7xl mx-auto">
    <div class="w-full md:w-[38%] flex flex-col">
      <div class="w-full text-stone-600 text-xl font-black  leading-6"><span class="bg-amarillo p-1 rounded-md">Apoyo Estatal en:</span></div>
      <div class="w-full text-cafemedio text-7xl font-black  uppercase leading-[77.49px] mt-4">Colombia</div>
      <div class="w-full text-stone-600 text-2xl font-medium  leading-7 mt-6">Mecanismos de</div>
      <div class="w-full text-verde text-4xl font-extrabold  uppercase leading-10">protección</div>
      <div class="bg-lime-200/40 p-2 mt-2 mr-20 rounded-md">
        <div class="flex items-center pl-6 gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 28 28" stroke-width="1.5" stroke="#818B3E" class="size-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <div class="w-60 h-16 justify-start text-stone-500 text-lg font-bold  leading-6 text-verde">Protocolo de protección de la Unidad de Protección Nacional</div>
        </div>
      </div>
      <div class="w-full text-stone-600 text-2xl font-medium  leading-7 mt-6">¿Cómo activar el</div>
      <div class="w-full text-verde text-4xl font-extrabold  uppercase leading-10">mecanismo?</div>
      <div class="w-72 text-stone-600 text-lg font-normal  leading-6 mt-4">
        Activar el protocolo de protección a través de una solicitud.
      </div>
    </div>

    <div class="w-full md:w-[62%] flex flex-col">
      <div class="w-full text-stone-600 text-lg font-black  leading-6 mb-4">
        Para activar el mecanismo de protección, puedes comunicarte directamente a los siguientes canales de contacto:
      </div>
      <div class="w-full">
        <span class="text-cafemedio text-lg font-black  leading-6">Web:</span>
        <a href="https://www.unp.gov.co/atencion-y-servicios-a-la-ciudadania/" target="_blank" rel="noopener noreferrer" class="text-stone-600 text-lg font-normal  underline leading-6 block">https://www.unp.gov.co/atencion-y-servicios-a-la-ciudadania/</a>
      </div>
    </div>
  </div>

  <div class="mt-8">
    <div class="text-center">
      <div class="w-full h-14 text-cafeoscuro text-2xl font-medium  leading-7">Acción estatal y entidades</div>
      <div class="w-full text-verde text-4xl font-extrabold  uppercase leading-10">de apoyo en Colombia</div>
      <div class="w-full h-4 text-cafeoscuro text-lg font-semibold  uppercase leading-6 mt-4">seleccionar institución:</div>
    </div>

    <div class="container max-w-full mx-auto px-4 mt-8">
      <div class="flex flex-wrap gap-4 justify-center py-6 mb-8">

        <template x-for="ubicacion in ubicaciones" :key="ubicacion.id">
          <button
            @click="selectedId = ubicacion.id"
            :class="selectedId === ubicacion.id ? 'bg-verde' : 'bg-cafeoscuro hover:bg-cafemedio'"
            class="px-2 sm:px-4 py-2 text-white font-medium rounded-full transition cursor-pointer text-sm sm:text-base"
          >
            <span x-text="ubicacion.titulo"></span>
          </button>
        </template>
      </div>
      
      <template x-for="ubicacion in ubicaciones" :key="ubicacion.id">
        <div x-show="selectedId === ubicacion.id" x-transition class="mt-4 bg-white rounded-xl p-6 border border-verde/20">
          <div class="text-amber-600 text-3xl font-black  uppercase mb-4" x-text="ubicacion.titulo"></div>
          <div class="w-full md:w-[62%]" x-html="ubicacion.contenido"></div>
        </div>
      </template>
    </div>
  </div>
</div>

<style>
[x-cloak] { display: none !important; }
</style>
