---
import { t } from '../../i18n/utils.ts';
import Accordion from '../../components/Accordion.astro';

const url = Astro.url.pathname;
const locale = url.includes('/pt/') ? 'pt' : 'es';

const ubicaciones = [
  {
    id: 'centro-denuncias',
    titulo: 'Centro de Denuncias',
    contenido: `
      <p class="text-white text-lg font-bold font-['Geologica'] leading-6 mb-2">La subsecretaría brineda asesoramiento jurídico, acompañamiento psico-social, y ayuda a realizar la denuncia penal correspondiente.</p>
      <p class="text-white text-lg font-normal font-['Geologica'] leading-6">
        Atención telefónica: 0-800-122-5878<br/>
        Vía Whatsapp: (+54) (11) 4091-7352<br/>
        Correo electrónico: <a href="mailto:denuncias@jus.gob.ar" class="text-white underline">denuncias@jus.gob.ar</a>
      </p>
    `
  },
  {
    id: 'defensoria',
    titulo: 'Defensoría del Pueblo',
    contenido: `
      <p class="text-white text-lg font-bold font-['Geologica'] leading-6 mb-2">Formulario de ayuda ante violaciones a los derechos humanos, violencia institucional, ambiente y salud.</p>
      <p class="text-white text-lg font-normal font-['Geologica'] leading-6">
        Link al formulario: <a href="https://www.defensor.gob.ar/contactoAreas.php?idS=4" target="_blank" rel="noopener noreferrer" class="text-white underline">https://www.defensor.gob.ar/contactoAreas.php?idS=4</a>
      </p>
    `
  }
];
---

<div class="bg-white mt-6">
  <div class="flex flex-col md:flex-row gap-6 md:gap-5 px-4 md:px-6 py-4 md:py-6 max-w-7xl mx-auto">
    <div class="w-full md:w-[38%] flex flex-col">
      <div class="w-full text-stone-600 text-xl font-black font-['Geologica'] leading-6"><span class="bg-amarillo p-1 rounded-md">Apoyo Estatal en:</span></div>
      <div class="w-full text-cafemedio text-7xl font-black font-['Geologica'] uppercase leading-[77.49px] mt-4">Argentina</div>
      <div class="w-full text-stone-600 text-2xl font-medium font-['Geologica'] leading-7 mt-6">Mecanismos de</div>
      <div class="w-full text-verde text-4xl font-extrabold font-['Geologica'] uppercase leading-10">protección</div>
      <div class="bg-lime-200/40 p-2 mt-2 mr-20 rounded-md">
        <div class="flex items-center pl-6 gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 28 28" stroke-width="1.5" stroke="#818B3E" class="size-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <div class="w-60 h-16 justify-start text-stone-500 text-lg font-bold font-['Geologica'] leading-6 text-verde">Mecanismo de recepción de denuncias</div>
        </div>
        <div class="flex items-center pl-6 gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 28 28" stroke-width="1.5" stroke="#818B3E" class="size-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <span class="text-verde text-lg font-bold font-['Geologica'] leading-8">Asistencia a víctimas de violaciones de DD.HH</span>
        </div>
      </div>
      <div class="w-full text-stone-600 text-2xl font-medium font-['Geologica'] leading-7 mt-6">¿Cómo activar el</div>
      <div class="w-full text-verde text-4xl font-extrabold font-['Geologica'] uppercase leading-10">mecanismo?</div>
      <div class="w-72 text-stone-600 text-lg font-normal font-['Geologica'] leading-6 mt-4">
        A través de la Secretaría de Derechos Humanos de la Nación.
      </div>
    </div>

    <div class="w-full md:w-[62%] flex flex-col">
      <div class="w-full text-stone-600 text-lg font-black font-['Geologica'] leading-6 mb-4">
        Para activar el mecanismo de protección, puedes comunicarte directamente a los siguientes canales de contacto:
      </div>
      <div class="w-full">
        <span class="text-cafemedio text-lg font-black font-['Geologica'] leading-6">Teléfono:</span>
        <span class="text-stone-600 text-lg font-normal font-['Geologica'] leading-6 block">(+54) (11) 5300-4000 Interno 76840</span>
      </div>
      <div class="w-full mt-4">
        <span class="text-cafemedio text-lg font-black font-['Geologica'] leading-6">Correo:</span>
        <a href="mailto:dngv@derhuman.jus.gov.ar" class="text-stone-600 text-lg font-normal font-['Geologica'] underline leading-6 block">dngv@derhuman.jus.gov.ar</a>
      </div>
    </div>
  </div>

  <div class="mt-8">
    <div class="text-center">
      <div class="w-full h-14 text-cafeoscuro text-2xl font-medium font-['Geologica'] leading-7">Acción estatal y entidades</div>
      <div class="w-full text-verde text-4xl font-extrabold font-['Geologica'] uppercase leading-10">de apoyo en Argentina</div>
      <div class="w-full h-4 text-cafeoscuro text-lg font-semibold font-['Geologica'] uppercase leading-6 mt-4">seleccionar institución:</div>
    </div>

    <div class="container max-w-6xl mx-auto px-4 mt-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start">
        {ubicaciones.map((ubicacion) => (
          <Accordion 
            id={ubicacion.id}
            title={ubicacion.titulo}
            content={ubicacion.contenido}
          />
        ))}
      </div>
    </div>
  </div>
</div>
