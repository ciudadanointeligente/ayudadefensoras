---

<div class="p-6 bg-white">
  <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-2 p-12">
    <h2 class="text-5xl md:text-7xl text-right font-extrabold text-cafemedio">{t('pais.brasil.titulo', locale)}</h2>
    <div class="md:ml-12 md:mr-22 text-cafeoscuro text-[16px]">
      <p class="mb-2 font-bold">{t('pais.brasil.descripcion', locale)}</p>
      <p class="mb-2">{t('pais.brasil.direccion', locale)}</p>
      <p class="mb-2">{t('pais.brasil.telefono', locale)}</p>
      <p>{t('pais.brasil.correo', locale)}</p>
    </div>
  </div>
  <p class="text-center mt-10 uppercase text-cafeoscuro font-bold">{t('pais.brasil.accionEstatal', locale)}</p>
  
  <div class="container max-w-4xl mx-auto px-4 mt-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start">
      {ubicaciones.map((ubicacion) => (
        <Accordion 
          id={ubicacion.id}
          title={ubicacion.titulo}
          content={ubicacion.contenido}
        />
      ))}
    </div>
  </div>
</div>