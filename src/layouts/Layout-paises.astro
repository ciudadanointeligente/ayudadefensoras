---
import "../styles/global.css";
import "@fontsource-variable/geologica";
import Banner from "../components/Banner.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { getLocaleFromUrl } from "../i18n/utils";

const { title } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const lang = locale === 'pt' ? 'pt-BR' : 'es';
---

<!doctype html>
<html lang={lang} class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Plataforma de apoyo y recursos para defensores medioambientales en América Latina." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script src="/scripts/htmx.js" is:inline></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>
      // @ts-ignore - Alpine está disponible en globalThis cuando se carga desde CDN
      document.body.addEventListener('htmx:load', function(event) {
        // @ts-ignore
        if (window.Alpine) {
          // @ts-ignore
          Alpine.initTree(event.detail.elt);
        }
      });
    </script>
    <title>Ayuda Defensores - {title} - Ciudadanía Inteligente</title>
  </head>
  <body class="overflow-x-hidden antialiased">
    <Banner />
    <Navbar currentPage={Astro.url.pathname} />
    <slot />
    <Footer />
  </body>
</html>

<style>
html,
body {
  font-family: 'Geologica Variable', sans-serif;
  margin: 0;
  padding: 0;
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
}

html {
  scrollbar-gutter: stable;
  overflow-y: scroll;
}

* {
  box-sizing: border-box;
}
</style>
